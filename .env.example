# Copy this file to .env and fill in your real credentials.
# Do NOT commit your real .env file.

# OpenAI API key (used for image generation/editing and storyboard text planning)
OPENAI_API_KEY=

# Higgsfield credentials (used for image-to-video generation).
# Get them from https://cloud.higgsfield.ai. Use EITHER form:
#
# 1) Single combined key:
HF_KEY=
#
# 2) OR separate key + secret (leave HF_KEY blank if you use these):
HF_API_KEY=
HF_API_SECRET=
