# Copy this file to .env and fill in your real credentials.
# Do NOT commit your real .env file.

# OpenAI API key (used for image generation/editing and storyboard text planning)
OPENAI_API_KEY=

# KlingAI credentials (used for image-to-video generation)
# These are used to build a short-lived JWT for authenticated requests.
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
