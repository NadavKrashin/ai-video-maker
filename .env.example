# Copy this file to .env and fill in your real credentials.
# Do NOT commit your real .env file.

# OpenAI API key (image generation/editing and storyboard text planning).
OPENAI_API_KEY=

# fal.ai key (image-to-video + all audio) — from https://fal.ai/dashboard/keys.
FAL_KEY=

# Cloudinary Admin API — only needed for the web-order intake commands
# (`pipeline.py orders` / `pipeline.py ingest`). From the Cloudinary console:
# Settings -> API Keys. The cloud name is public and lives in config.json.
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
