# Copy this file to .env and fill in your real credentials.
# Do NOT commit your real .env file.

# OpenAI API key (used for image generation/editing and storyboard text planning)
OPENAI_API_KEY=

# KlingAI credentials (used for image-to-video generation).
#
# The OFFICIAL Kling Open Platform uses an ACCESS KEY + SECRET KEY pair, signed
# into a short-lived JWT. This is the scheme you almost certainly want.
#   IMPORTANT: the SECRET KEY is shown ONLY ONCE, at key-creation time. The value
#   listed in the console afterwards (e.g. "api-key-kling-...") is the ACCESS KEY.
#   If you no longer have the Secret Key, create a NEW key and copy both values
#   immediately.
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
#
# Optional: some third-party Kling resellers issue a single bearer API key
# instead. If that's you, set this and leave the AK/SK pair blank.
KLING_API_KEY=
