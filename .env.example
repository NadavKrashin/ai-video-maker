# Copy this file to .env and fill in your real credentials.
# Do NOT commit your real .env file.

# OpenAI API key (used for image generation/editing and storyboard text planning)
OPENAI_API_KEY=

# Image-to-video credentials. You only need the provider selected by
# "video_provider" in config.json (default: "fal").
#
# fal.ai (default, recommended) — one key from https://fal.ai/dashboard/keys:
FAL_KEY=
#
# Higgsfield (only if video_provider="higgsfield") — from https://cloud.higgsfield.ai.
# Use EITHER the single combined key...
# HF_KEY=
# ...OR the separate pair:
# HF_API_KEY=
# HF_API_SECRET=
