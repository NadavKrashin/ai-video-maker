# Copy this file to .env and fill in your real credentials.
# Do NOT commit your real .env file.

# OpenAI API key (used for image generation/editing and storyboard text planning)
OPENAI_API_KEY=

# KlingAI credentials (used for image-to-video generation).
#
# Use ONE of the two schemes below depending on what your Kling console shows:
#
# 1) SINGLE API KEY (most common — the console shows one "API Key" like
#    "api-key-kling-..."). Set this and leave the AK/SK pair blank.
KLING_API_KEY=
#
# 2) ACCESS KEY + SECRET KEY pair (the console shows two values). Set both and
#    leave KLING_API_KEY blank. A short-lived JWT is signed from these.
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
